{
  "name": "guillaumeferrari/uplift-ab-testing",
  "description": "Uplift – A/B Testing: lightweight A/B testing for pages with internal tracking and a 50/50 cookie split.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^4.0",
    "wp-phpunit/wp-phpunit": "^6.9",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Abtest\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Abtest\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:integration": "phpunit -c phpunit-integration.xml.dist",
    "lint": "phpcs --standard=phpcs.xml.dist",
    "lint:fix": "phpcbf --standard=phpcs.xml.dist"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
